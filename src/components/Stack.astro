---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import config from '../config';
---

<Section id="stack" number="02" title="Stack">
  <div class="reveal grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
    {
      config.technologies.map((tech) => (
        <div class="group hover:bg-surface/50 flex items-center gap-3 border p-5 transition-all hover:border-neutral-700">
          <Image src={tech.icon} alt={tech.name} width={32} height={32} loading="eager" />
          <span class="font-mono text-sm text-neutral-300">{tech.name}</span>
        </div>
      ))
    }
  </div>
</Section>
