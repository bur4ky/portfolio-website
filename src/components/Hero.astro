---
import config from '../config';
---

<section class="flex flex-col justify-end pt-64 pb-20">
  <p class="section-label reveal">
    {config.profession}
  </p>

  <h1
    class="font-display reveal mt-8 text-[clamp(6rem,15vw,12rem)] leading-[0.85] tracking-tight text-neutral-100 delay-100"
  >
    {config.name}<span class="text-accent">.</span>
  </h1>

  <p class="reveal mt-4 max-w-lg text-lg text-neutral-400 delay-200">
    {config.about}
  </p>

  <div class="reveal pt- mt-4 flex items-center gap-8 delay-300">
    <a
      href={`mailto:${config.contactEmail}`}
      class="text-accent hover:text-accent/80 border-accent/30 border-b pb-0.5 font-mono text-sm transition-colors"
    >
      {config.contactEmail}
    </a>
    <a
      href={`https://github.com/${config.github}`}
      target="_blank"
      class="font-mono text-sm text-neutral-500 transition-colors hover:text-neutral-300"
    >
      GitHub ↗
    </a>
  </div>
</section>
