---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import config from '../config';
---

<Section id="projects" number="01" title="My Work">
  <div class="divide-border space-y-20 divide-y">
    {
      config.projects.map((project, i) => (
        <div
          class={`${i % 2 !== 0 ? 'direction-rtl' : ''} reveal grid items-start gap-8 pb-16 last:pb-0 md:grid-cols-5`}
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <div class={`overflow-hidden md:col-span-3 ${i % 2 !== 0 ? 'md:order-2' : ''}`}>
            <Image
              src={project.thumbnail}
              alt={project.title}
              class="aspect-video w-full object-cover"
              width={720}
              height={405}
              loading="eager"
            />
          </div>

          <div
            class={`flex h-full flex-col justify-between py-2 md:col-span-2 ${i % 2 !== 0 ? 'direction-ltr md:order-1' : ''}`}
          >
            <div>
              <h3 class="text-xl font-medium text-neutral-100">{project.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-neutral-400">{project.description}</p>

              <div class="mt-6 mb-8 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="border px-2.5 py-1 font-mono text-xs">{tag}</span>
                ))}
              </div>
            </div>

            <div class="flex items-center gap-4 font-mono text-sm">
              {project.repository && (
                <a
                  href={project.repository}
                  target="_blank"
                  class="hover:text-accent text-neutral-500 transition-colors"
                >
                  Source ↗
                </a>
              )}
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  class="hover:text-accent text-neutral-500 transition-colors"
                >
                  Live ↗
                </a>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</Section>
